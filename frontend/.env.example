VITE_API_BASE_URL=http://127.0.0.1:8000

# Fallback API (mock) : UNIQUEMENT pour dev / démo sans Django.
# - false ou absent : les erreurs réelles (404, 5xx, réseau) s’affichent — comportement attendu en production.
# - true : sur 404/405/501/503 uniquement, webFeaturesApi renvoie des données de démo et la bannière jaune liste les routes concernées.
# Ne pas activer sur un déploiement « vrai » : vous masqueriez l’absence ou la panne du backend.
VITE_ENABLE_API_FALLBACK=false
