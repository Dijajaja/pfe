# Installation PostgreSQL (Windows) : voir SETUP_POSTGRES.txt à la racine du dossier backend.

DEBUG=True
SECRET_KEY=change-me
ALLOWED_HOSTS=127.0.0.1,localhost

# Base PostgreSQL (défaut du projet)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=cnou_bourses
DB_USER=cnou_app
DB_PASSWORD=12345
DB_HOST=127.0.0.1
DB_PORT=5432
# Durée de persistance des connexions (secondes, 0 = nouvelle connexion à chaque requête)
# DB_CONN_MAX_AGE=600

# Pour tests locaux sans PostgreSQL uniquement :
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
